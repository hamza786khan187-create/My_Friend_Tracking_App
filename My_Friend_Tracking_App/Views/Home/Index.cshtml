</style>

<!-- ==================== MAP SCREEN ==================== -->
<div class="mobile-screen" id="app-screen-map">
    <div class="map-container-wrapper">

        <div class="map-overlay-search">
            <i class="fas fa-search" style="color:#94a3b8;"></i>
            <input type="text" id="mapSearchInput" placeholder="Search location...">
            <i class="fas fa-microphone" style="color:#94a3b8;"></i>
        </div>

        <div class="filter-chips">
            <div class="chip"><i class="fas fa-utensils"></i> Restaurants</div>
            <div class="chip"><i class="fas fa-gas-pump"></i> Gas</div>
            <div class="chip"><i class="fas fa-coffee"></i> Coffee</div>
            <div class="chip"><i class="fas fa-shopping-bag"></i> Shops</div>
        </div>

        <div class="permission-toggle-btn" onclick="togglePermissionPanel()">
            <i class="fas fa-sliders-h"></i>
        </div>

        <div class="permission-panel" id="privacyControlPanel">
            <h4 style="margin:0 0 12px;font-size:14px;color:#0b5499;">
                <i class="fas fa-shield-alt"></i> Privacy Controls
            </h4>
            <div class="permission-item">
                <div class="permission-text">
                    <h5>Allow My Live Location</h5>
                    <p>Doston ko live position dikhayein</p>
                </div>
                <label class="switch">
                    <input type="checkbox" id="permAllowLocation" checked onchange="updatePrivacySettings()">
                    <span class="slider"></span>
                </label>
            </div>
            <div class="permission-item">
                <div class="permission-text">
                    <h5>Save Location History</h5>
                    <p>Database mein timestamps save karein</p>
                </div>
                <label class="switch">
                    <input type="checkbox" id="permSaveHistory" checked onchange="updatePrivacySettings()">
                    <span class="slider"></span>
                </label>
            </div>
            <div class="permission-item" style="border-bottom:none;margin-bottom:0;">
                <div class="permission-text">
                    <h5>Background Tracking</h5>
                    <p>App band hone par bhi track karein</p>
                </div>
                <label class="switch">
                    <input type="checkbox" id="permBackground" onchange="updatePrivacySettings()">
                    <span class="slider"></span>
                </label>
            </div>
        </div>

        <div id="map"></div>

        <div class="locate-fab" onclick="locateMe()">
            <i class="fas fa-location-arrow"></i>
        </div>
