LEAFLET SEEDHA YAHAN LOAD — kisi bhi layout dependency ke baghair
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
    const LOGGED_USER_ID = "@Context.Session.GetInt32("UserId")";
    let liveMapInstance = null;
    let mainUserMarker = null;
    let activeFriendMarkers = {};
    let activePopups = {};

    const initialFriendMarkers = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
        Model.FriendMarkers ?? new List<My_Friend_Tracking_App.Models.FriendModel>()));

    // ======== GLOBAL FUNCTIONS — onclick ke liye ========
    function togglePermissionPanel() {
        document.getElementById('privacyControlPanel').classList.toggle('active');
    }

    function updatePrivacySettings() {
        const isAllowed = document.getElementById('permAllowLocation').checked;
        const saveHistory = document.getElementById('permSaveHistory').checked;
        console.log(`Privacy -> AllowLocation: ${isAllowed}, SaveHistory: ${saveHistory}`);
    }

    function locateMe() {
        if (!navigator.geolocation || !liveMapInstance) return;
        navigator.geolocation.getCurrentPosition(pos => {
            const lat = pos.coords.latitude;
            const lng = pos.coords.longitude;
            liveMapInstance.setView([lat, lng], 16);
            if (mainUserMarker) {
                mainUserMarker.setLatLng([lat, lng]);
            } else {
                mainUserMarker = L.marker([lat, lng])
                    .addTo(liveMapInstance)
                    .bindPopup('<b>Aap Ki Live Location</b>')
                    .openPopup();
            }
        }, () => { alert("GPS check karein."); });
    }

    function switchDashboardTab(tab, el) {
        document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
        if (el) el.classList.add('active');
        if (tab === 'friends') {
            document.getElementById('app-screen-map').style.display = 'none';
            document.getElementById('app-screen-friends').style.display = 'flex';
        } else {
            document.getElementById('app-screen-friends').style.display = 'none';
            document.getElementById('app-screen-map').style.display = 'flex';
            if (liveMapInstance) setTimeout(() => { liveMapInstance.invalidateSize(); }, 100);
        }
    }

    function focusAndLocateFriend(friendId) {
        switchDashboardTab('map', document.getElementById('nav-btn-map'));
        const marker = activeFriendMarkers[friendId];
        if (marker) {
            setTimeout(() => {
                liveMapInstance.setView(marker.getLatLng(), 16);
                marker.openPopup();
            }, 200);
        } else {
            alert("Is dost ki live location available nahi hai.");
        }
    }

    // ======== MAP INIT ========
    function checkLocationPermissionsAndInit() {
        if (!navigator.geolocation) {
            initMapSystem(33.6007, 73.0679);
            return;
        }
        navigator.geolocation.getCurrentPosition(
            (pos) => {
                initMapSystem(pos.coords.latitude, pos.coords.longitude);
                trackDeviceGeographicalCoordinates();
            },
            () => { initMapSystem(33.6007, 73.0679); },
            { enableHighAccuracy: true, timeout: 10000 }
        );
    }

    function initMapSystem(startLat, startLng) {
        if (liveMapInstance) return;

        liveMapInstance = L.map('map', {
            center: [startLat, startLng],
            zoom: 15,
            zoomControl: true
        });

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
            maxZoom: 19
        }).addTo(liveMapInstance);

        const isDefault = (startLat === 33.6007 && startLng === 73.0679);
        if (!isDefault) {
            mainUserMarker = L.marker([startLat, startLng])
                .addTo(liveMapInstance)
                .bindPopup('<b>Aap Ki Live Location</b>')
                .openPopup();
        }

        if (initialFriendMarkers && initialFriendMarkers.length > 0) {
            initialFriendMarkers.forEach(f => updateOrAppendFriendMarker(f));
        }

        setTimeout(() => { liveMapInstance.invalidateSize(); }, 300);
    }

    function updateOrAppendFriendMarker(friend) {
        if (!friend.Latitude || !friend.Longitude || !liveMapInstance) return;
        const markerId = friend.UserId || friend.FriendId;
        if (!markerId) return;

        const lat = parseFloat(friend.Latitude);
        const lng = parseFloat(friend.Longitude);
        const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

        const popupHtml = `
            <div style="font-family:sans-serif;min-width:130px;">
                <strong style="color:#0b5499;">${friend.FullName}</strong><br>
                <span style="font-size:11px;color:#475569;">${friend.PhoneNo || 'N/A'}</span><br>
                <span style="font-size:10px;color:#10b981;font-weight:bold;">Live: ${time}</span>
            </div>`;

        if (activeFriendMarkers[markerId]) {
            activeFriendMarkers[markerId].setLatLng([lat, lng]);
            if (activePopups[markerId]) activePopups[markerId].setContent(popupHtml);
        } else {
            const marker = L.marker([lat, lng]).addTo(liveMapInstance);
            const popup = marker.bindPopup(popupHtml).getPopup();
            marker.on('click', () => marker.openPopup());
            activeFriendMarkers[markerId] = marker;
            activePopups[markerId] = popup;
        }
    }

    function initSearchBox() {
        const input = document.getElementById('mapSearchInput');
        if (!input) return;
        input.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') searchNominatim(input.value.trim());
        });
    }

    async function searchNominatim(query) {
        if (!query || !liveMapInstance) return;
        try {
            const res = await fetch(
                `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(query)}&format=json&limit=1`,
                { headers: { 'Accept-Language': 'en' } }
            );
            const data = await res.json();
            if (data && data.length > 0) {
                const lat = parseFloat(data[0].lat);
                const lon = parseFloat(data[0].lon);
                liveMapInstance.setView([lat, lon], 16);
                L.marker([lat, lon]).addTo(liveMapInstance)
                    .bindPopup(`<b>${data[0].display_name}</b>`).openPopup();
            } else {
                alert("Location nahi mila.");
            }
        } catch (err) {
            console.error("Search error:", err);
        }
    }

    async function fetchLiveMovingFriendsUpdates() {
        if (!LOGGED_USER_ID || !liveMapInstance) return;
        try {
            const res = await fetch('/Home/GetFriendsLocation');
            if (res.ok) {
                const data = await res.json();
                if (data && data.length > 0) data.forEach(f => updateOrAppendFriendMarker(f));
            }
        } catch (err) {
            console.warn("Live update error:", err);
        }
    }

    function trackDeviceGeographicalCoordinates() {
        if (!navigator.geolocation) return;
        navigator.geolocation.watchPosition(async (pos) => {
            if (!document.getElementById('permAllowLocation').checked) return;
            const { latitude, longitude } = pos.coords;
            if (mainUserMarker) {
                mainUserMarker.setLatLng([latitude, longitude]);
            } else if (liveMapInstance) {
                mainUserMarker = L.marker([latitude, longitude])
                    .addTo(liveMapInstance)
                    .bindPopup('<b>Aap Ki Live Location</b>');
            }
            if (LOGGED_USER_ID && LOGGED_USER_ID !== "") {
                try {
                    await fetch('/Home/SaveLocation', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            userId: parseInt(LOGGED_USER_ID),
                            latitude: parseFloat(latitude),
                            longitude: parseFloat(longitude)
                        })
                    });
                } catch (err) {
                    console.error("Location save error:", err);
                }
            }
        }, err => console.error("WatchPosition error:", err), { enableHighAccuracy: true });
    }

    ///======= START — DOM ready hone ke baad ========
    document.addEventListener('DOMContentLoaded', function () {
        checkLocationPermissionsAndInit();
        setInterval(fetchLiveMovingFriendsUpdates, 5000);
        initSearchBox();
    });
</script>  *@