    <div class="bottom-nav">
        <div class="nav-item active" id="nav-btn-map" onclick="switchDashboardTab('map', this)">
            <i class="fas fa-map-marked-alt"></i><span>Map</span>
        </div>
        <div class="nav-item" id="nav-btn-friends" onclick="switchDashboardTab('friends', this)">
            <i class="fas fa-user-friends"></i><span>Friends</span>
        </div>
        <div class="nav-item">
            <i class="fas fa-bell"></i><span>Notification</span>
        </div>
        <a asp-action="Profile" asp-controller="Account" class="nav-item">
            <i class="fas fa-user-circle"></i><span>Profile</span>
        </a>
    </div>
</div>

